# WeKnora production automation config example
# Usage:
#   cp my_docs/运维部署/20260528-02-weknora-prod-automation.env.example \
#      my_docs/运维部署/20260528-02-weknora-prod-automation.env
#   chmod 600 my_docs/运维部署/20260528-02-weknora-prod-automation.env
#   Edit every placeholder before running deploy commands.

# ========== Common release settings ==========
REGISTRY=registry.example.com/weknora
RELEASE_VERSION=0.6.0-20260528.1
PLATFORM=linux/amd64
TARGETARCH=amd64
MAX_FILE_SIZE_MB=50
DRY_RUN=false

# Build acceleration / private modules
GOPROXY=https://goproxy.cn,direct
GOSUMDB=off
GOPRIVATE=
APT_MIRROR=
APK_MIRROR_ARG=

# Optional artifact switches
PACKAGE_LITE=true
PACKAGE_MCP=true
PACKAGE_CLIENT_SDK=true
RUN_SOURCE_TESTS=false

# ========== Production runtime settings ==========
DOMAIN=weknora.example.com
APP_EXTERNAL_URL=https://weknora.example.com
TZ=Asia/Shanghai
WEKNORA_LANGUAGE=zh-CN
DISABLE_REGISTRATION=true

DB_USER=weknora
DB_PASSWORD=change-me-strong-db-password
DB_NAME=weknora
DB_DRIVER=postgres
DB_HOST=postgres
DB_PORT=5432
RETRIEVE_DRIVER=postgres
AUTO_RECOVER_DIRTY=true

REDIS_PASSWORD=change-me-strong-redis-password
REDIS_DB=0
REDIS_PREFIX=stream:
STREAM_MANAGER_TYPE=redis

STORAGE_TYPE=minio
MINIO_ENDPOINT=https://minio.example.com
MINIO_INTERNAL_ENDPOINT=minio:9000
MINIO_ACCESS_KEY_ID=change-me-object-storage-access-key
MINIO_SECRET_ACCESS_KEY=change-me-object-storage-secret-key
MINIO_BUCKET_NAME=weknora-prod
MINIO_PATH_PREFIX=prod
MINIO_USE_SSL=true
LOCAL_STORAGE_BASE_DIR=/data/files

FRONTEND_PORT=80
APP_PORT=8080
APP_BACKEND_PORT=8080
APP_HOST=app
APP_SCHEME=http
DOCREADER_ADDR=docreader:50051
DOCREADER_TRANSPORT=grpc

JWT_SECRET=change-me-openssl-rand-base64-48
TENANT_AES_KEY=change-me-keep-stable-value
SYSTEM_AES_KEY=change-me-exactly-32-byte-value
CRYPTO_MASTER_KEY=change-me-openssl-rand-hex-32
CRYPTO_SALT=change-me-openssl-rand-base64-32

WEKNORA_SANDBOX_MODE=docker
WEKNORA_SANDBOX_TIMEOUT=60

# Model / observability settings
OLLAMA_BASE_URL=http://ollama.ollama.svc.cluster.local:11434
LANGFUSE_ENABLED=
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ========== Docker Compose deployment ==========
COMPOSE_PROJECT_DIR=/opt/weknora
COMPOSE_PROFILES=
COMPOSE_PULL=false
COMPOSE_PREPARE_COPY=true
COMPOSE_BACKUP_DIR=/opt/weknora/backups

# ========== Kubernetes / Helm deployment ==========
HELM_NAMESPACE=weknora
HELM_RELEASE=weknora
HELM_FULLNAME=weknora
HELM_VALUES_FILE=/tmp/weknora-values-production.yaml
HELM_STORAGE_CLASS=fast-ssd
HELM_APP_REPLICAS=2
HELM_FRONTEND_REPLICAS=2
HELM_DOCREADER_REPLICAS=1
HELM_POSTGRES_SIZE=100Gi
HELM_REDIS_SIZE=10Gi
HELM_INGRESS_CLASS=nginx
HELM_TLS_SECRET=weknora-tls
HELM_IMAGE_PULL_SECRET=regcred

# Optional registry secret automation. Leave empty if your cluster already has imagePullSecret.
REGISTRY_USERNAME=
REGISTRY_PASSWORD=

# Optional TLS secret automation. Leave empty if TLS secret already exists.
TLS_CERT_FILE=
TLS_KEY_FILE=

# Kubernetes backup output directory on the operator machine.
K8S_BACKUP_DIR=./backups
